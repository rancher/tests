#!groovy
/**
 * Freeform validation pipeline for running Go test suites against an existing Rancher instance.
 *
 * Checks out the test repository, builds the validation Docker image via configure.sh
 * and build.sh, and runs gotestsum-based test suites inside the container. Optionally
 * captures Docker images used during the run and reports results to Qase.
 *
 * Does NOT provision infrastructure or deploy Rancher.
 *
 * Consumes shared functions from qa-jenkins-library:
 *   property.useWithProperties
 *
 * Qase reporting script is resolved in priority order:
 *   QASE_REPORTER_SCRIPT > REPORTER_BUILD_SCRIPT > build_qase_reporter.sh (default)
 */

def libraryBranch = env.QA_JENKINS_LIBRARY_BRANCH ?: 'main'
library "qa-jenkins-library@${libraryBranch}"

pipeline {
    agent any

    options {
        ansiColor('xterm')
        timeout(time: 180, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '30'))
    }

    environment {
        ROOT_PATH          = '/root/go/src/github.com/rancher/tests/validation/'
        TEST_RESULTS       = 'results.xml'
        TEST_RESULTS_JSON  = 'results.json'
        ENV_FILE           = '.env'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    withEnv([
                        "TIMEOUT=${env.TIMEOUT ?: '60m'}",
                        "CONFIG=${env.CONFIG ?: ''}",
                        "TEST_PACKAGE=${env.TEST_PACKAGE ?: '...'}",
                        "GOTEST_TESTCASE=${env.GOTEST_TESTCASE ?: ''}",
                        "TAGS=${env.TAGS ?: 'validation'}",
                        "ENV_VARIABLE=${env.ENV_VARIABLE ?: ''}",
                        "CAPTURE_IMAGES=${env.CAPTURE_IMAGES ?: 'false'}",
                        "REPO=${env.REPO ?: 'https://github.com/rancher/tests'}",
                        "BRANCH=${env.BRANCH ?: 'main'}",
                        "REPORTER_BUILD_SCRIPT=${env.REPORTER_BUILD_SCRIPT ?: ''}",
                        "QASE_REPORTER_SCRIPT=${env.QASE_REPORTER_SCRIPT ?: ''}"
                    ]) {
                        // Persist defaults to env so they are available in subsequent stages
                        env.TIMEOUT               = env.TIMEOUT
                        env.CONFIG                = env.CONFIG
                        env.TEST_PACKAGE          = env.TEST_PACKAGE
                        env.GOTEST_TESTCASE       = env.GOTEST_TESTCASE
                        env.TAGS                  = env.TAGS
                        env.ENV_VARIABLE          = env.ENV_VARIABLE
                        env.CAPTURE_IMAGES        = env.CAPTURE_IMAGES
                        env.REPO                  = env.REPO
                        env.BRANCH                = env.BRANCH
                        env.REPORTER_BUILD_SCRIPT = env.REPORTER_BUILD_SCRIPT
                        env.QASE_REPORTER_SCRIPT  = env.QASE_REPORTER_SCRIPT

                        deleteDir()
                        checkout([
                            $class: 'GitSCM',
                            branches: [[name: "*/${env.BRANCH}"]],
                            extensions: [[$class: 'CleanCheckout']],
                            userRemoteConfigs: [[url: env.REPO]]
                        ])
                        env.RANCHER_TEST_COMMIT_ID = sh(script: 'git rev-parse HEAD', returnStdout: true).trim()
                        echo "rancher/tests commit ID: ${env.RANCHER_TEST_COMMIT_ID}"
                        currentBuild.displayName = "#${env.BUILD_NUMBER} - ${env.TAGS}"

                        // Derive unique container/image names early so post.always can always clean up
                        def jobName = env.JOB_NAME.contains('/') ? env.JOB_NAME.split('/')[-1] : env.JOB_NAME
                        env.IMAGE_NAME         = "rancher-validation-${jobName}${env.BUILD_NUMBER}"
                        env.TEST_CONTAINER     = "${jobName}${env.BUILD_NUMBER}_test"
                        env.REPORTER_CONTAINER = "${jobName}${env.BUILD_NUMBER}_reporter"
                    }
                }
            }
        }

        stage('Configure and Build') {
            steps {
                script {
                    property.useWithProperties([
                        'AWS_ACCESS_KEY_ID',
                        'AWS_SECRET_ACCESS_KEY',
                        'DO_ACCESSKEY',
                        'AWS_SSH_PEM_KEY',
                        'AWS_SSH_RSA_KEY',
                        'RANCHER_SSH_KEY',
                        'AZURE_SUBSCRIPTION_ID',
                        'AZURE_TENANT_ID',
                        'AZURE_CLIENT_ID',
                        'AZURE_CLIENT_SECRET',
                        'RANCHER_REGISTRY_USER_NAME',
                        'RANCHER_REGISTRY_PASSWORD',
                        'RANCHER_AD_SPECIAL_CHAR_PASSWORD',
                        'ADMIN_PASSWORD',
                        'USER_PASSWORD',
                        'RANCHER_GKE_CREDENTIAL',
                        'RANCHER_AUTH_USER_PASSWORD',
                        'RANCHER_HOSTNAME_OR_IP_ADDRESS',
                        'RANCHER_CA_CERTIFICATE',
                        'RANCHER_SERVICE_ACCOUNT_NAME',
                        'RANCHER_SERVICE_ACCOUNT_PASSWORD',
                        'RANCHER_USER_SEARCH_BASE',
                        'RANCHER_DEFAULT_LOGIN_DOMAIN',
                        'RANCHER_OPENLDAP_SERVICE_ACCOUNT_NAME',
                        'RANCHER_OPENLDAP_SERVICE_ACCOUNT_PASSWORD',
                        'RANCHER_OPENLDAP_USER_SEARCH_BASE',
                        'RANCHER_OPENLDAP_AUTH_USER_PASSWORD',
                        'RANCHER_OPENLDAP_HOSTNAME_OR_IP_ADDRESS',
                        'RANCHER_OPENLDAP_SPECIAL_CHAR_PASSWORD',
                        'RANCHER_FREEIPA_SERVICE_ACCOUNT_NAME',
                        'RANCHER_FREEIPA_SERVICE_ACCOUNT_PASSWORD',
                        'RANCHER_FREEIPA_USER_SEARCH_BASE',
                        'RANCHER_FREEIPA_GROUP_SEARCH_BASE',
                        'RANCHER_FREEIPA_AUTH_USER_PASSWORD',
                        'RANCHER_FREEIPA_HOSTNAME_OR_IP_ADDRESS',
                        'RANCHER_FREEIPA_SPECIAL_CHAR_PASSWORD',
                        'RANCHER_VALID_TLS_CERT',
                        'RANCHER_VALID_TLS_KEY',
                        'RANCHER_BYO_TLS_CERT',
                        'RANCHER_BYO_TLS_KEY',
                        'QASE_AUTOMATION_TOKEN',
                        'SLACK_WEBHOOK',
                        'RANCHER_LINODE_ACCESSKEY',
                        'APPCO_USERNAME',
                        'APPCO_ACCESS_TOKEN'
                    ]) {
                        if (env.AWS_SSH_PEM_KEY && env.AWS_SSH_KEY_NAME) {
                            dir('./validation/.ssh') {
                                writeFile file: env.AWS_SSH_KEY_NAME, text: new String(env.AWS_SSH_PEM_KEY.decodeBase64())
                            }
                        }

                        dir('./validation') {
                            writeFile file: 'config.yaml', text: env.CONFIG ?: ''
                            env.CATTLE_TEST_CONFIG = env.ROOT_PATH + 'config.yaml'
                        }

                        sh './validation/configure.sh'
                        sh './validation/build.sh'

                        if (env.ENV_VARIABLE?.trim()) {
                            def envText = readFile(env.ENV_FILE)
                            writeFile file: env.ENV_FILE, text: envText + env.ENV_VARIABLE
                        }
                    }
                }
            }
        }

        stage('Run Validation Tests') {
            steps {
                script {
                    if (env.CAPTURE_IMAGES == 'true') {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                            sh 'mkdir -p ./validation/image-report'
                            sh """
                                docker run -d --name imageCapturer \
                                    -v ./validation/image-report:/app/image-report \
                                    -v ./validation/config.yaml:/app/config.yaml \
                                    -t ${env.IMAGE_NAME} sh -c \
                                    'go build -o /app/capturer ../scripts/capture_images/capture_images.go && \
                                    CATTLE_TEST_CONFIG=/app/config.yaml exec /app/capturer'
                            """
                            sh 'grep -qm 1 "Listening to events on cluster" <(docker logs -f imageCapturer)'
                        }
                    }

                    def testCmd = "/root/go/bin/gotestsum --format standard-verbose" +
                        " --packages=github.com/rancher/tests/validation/${env.TEST_PACKAGE}" +
                        " --junitfile ${env.TEST_RESULTS}" +
                        " --jsonfile ${env.TEST_RESULTS_JSON}" +
                        " -- -tags=${env.TAGS}" +
                        (env.GOTEST_TESTCASE?.trim() ? " ${env.GOTEST_TESTCASE.trim()}" : '') +
                        " -timeout=${env.TIMEOUT} -v"

                    catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                        sh """
                            docker run --name ${env.TEST_CONTAINER} -t \
                                --env-file ${env.ENV_FILE} \
                                ${env.IMAGE_NAME} \
                                sh -c "${testCmd}"
                        """
                    }
                    sh "docker cp ${env.TEST_CONTAINER}:${env.ROOT_PATH}${env.TEST_RESULTS_JSON} ."

                    if (env.CAPTURE_IMAGES == 'true') {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                            sh 'docker kill --signal SIGTERM imageCapturer && docker wait imageCapturer'
                            echo readFile('./validation/image-report/image-report.txt')
                            sh 'docker rm imageCapturer'
                        }
                    }

                    // QASE_REPORTER_SCRIPT takes priority; fall back to REPORTER_BUILD_SCRIPT, then the default.
                    def reporterScript = env.QASE_REPORTER_SCRIPT ?: env.REPORTER_BUILD_SCRIPT ?: 'build_qase_reporter.sh'
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        sh """
                            docker run --name ${env.REPORTER_CONTAINER} -t \
                                --env-file ${env.ENV_FILE} \
                                -v ./validation/image-report:/app/image-report \
                                -v ./results.json:${env.ROOT_PATH}results.json \
                                ${env.IMAGE_NAME} \
                                sh -c "${env.ROOT_PATH}pipeline/scripts/${reporterScript}; \
                                    if [ -f ./reporter ]; then ./reporter; else echo 'Reporter script not present'; fi"
                        """
                    }
                }
            }
        }

        stage('Test Report') {
            steps {
                script {
                    sh "docker cp ${env.TEST_CONTAINER}:${env.ROOT_PATH}${env.TEST_RESULTS} ."
                    junit allowEmptyResults: true, testResults: "**/${env.TEST_RESULTS}"
                    archiveArtifacts allowEmptyArchive: true,
                        artifacts: "${env.TEST_RESULTS}, ${env.TEST_RESULTS_JSON}",
                        fingerprint: true
                }
            }
        }
    }

    post {
        always {
            sh "docker stop ${env.TEST_CONTAINER} || true"
            sh "docker rm -v ${env.TEST_CONTAINER} || true"
            sh "docker rm -v ${env.REPORTER_CONTAINER} || true"
            sh "docker rmi -f ${env.IMAGE_NAME} || true"
        }
    }
}
