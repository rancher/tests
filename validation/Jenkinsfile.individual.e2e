#!groovy
/**
 * Test-only pipeline for running Go test suites against an existing Rancher instance.
 *
 * Triggered as a downstream job by validation/Jenkinsfile.e2e after infrastructure
 * provisioning, Rancher deployment, and admin token injection are complete.
 *
 * Does NOT provision infrastructure or deploy Rancher.
 *
 * Consumes shared functions from qa-jenkins-library:
 *   property.useWithProperties
 *
 * Parameter names (CONFIG, REPO, BRANCH, TAGS, GOTEST_TESTCASE, etc.) match the
 * existing go-automation-freeform-job pattern for compatibility with downstream
 * triggers from both the new E2E pipeline and the legacy recurring pipeline.
 */

def libraryBranch = env.QA_JENKINS_LIBRARY_BRANCH ?: 'main'
library "qa-jenkins-library@${libraryBranch}"

pipeline {
    agent any

    options {
        ansiColor('xterm')
        timeout(time: 180, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '30'))
    }

    parameters {
        // ── Test execution parameters ────────────────────────────
        string(
            name: 'TIMEOUT',
            defaultValue: '60m',
            description: 'Go test timeout duration (e.g., 60m, 2h)'
        )
        text(
            name: 'CONFIG',
            defaultValue: '',
            description: 'Test configuration YAML (cattle-config with admin token already injected by orchestrator)'
        )
        string(
            name: 'TEST_PACKAGE',
            defaultValue: './validation/...',
            description: 'Go test package path (e.g., ./validation/..., ./validation/provisioning/rke2/...)'
        )
        string(
            name: 'GOTEST_TESTCASE',
            defaultValue: '',
            description: 'Go test case regex (-run flag). Empty = all tests in the package.'
        )
        string(
            name: 'TAGS',
            defaultValue: 'validation',
            description: 'Go build tags (e.g., validation, pit.daily, recurring)'
        )

        // ── Repository parameters ────────────────────────────────
        string(
            name: 'REPO',
            defaultValue: 'https://github.com/rancher/tests',
            description: 'Test repository URL'
        )
        string(
            name: 'BRANCH',
            defaultValue: 'main',
            description: 'Test repository branch'
        )

        // ── Qase reporting parameters ────────────────────────────
        string(
            name: 'QASE_TEST_RUN_ID',
            defaultValue: '',
            description: 'Qase test run ID. Enables Qase reporting when set.'
        )
        string(
            name: 'QASE_REPORTER_SCRIPT',
            defaultValue: 'build_qase_reporter_v2.sh',
            description: 'Qase reporter script name in validation/pipeline/scripts/'
        )
        text(
            name: 'ENV_VARIABLE',
            defaultValue: '',
            description: 'Additional KEY=VALUE line to append to the .env file before running tests'
        )
        // ── Library parameter ────────────────────────────────────
        string(
            name: 'QA_JENKINS_LIBRARY_BRANCH',
            defaultValue: 'main',
            description: 'Branch of qa-jenkins-library to use'
        )
        booleanParam(
            name: 'CAPTURE_IMAGES',
            defaultValue: true,
            description: 'When true, captures Docker images used during the test run'
        )
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    deleteDir()
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "*/${params.BRANCH}"]],
                        extensions: [[$class: 'CleanCheckout']],
                        userRemoteConfigs: [[url: params.REPO]]
                    ])
                    env.TESTS_DIR = pwd()
                    currentBuild.displayName = "#${env.BUILD_NUMBER} - ${params.TAGS}"
                }
            }
        }

        stage('Build Test Image') {
            steps {
                sh 'docker build --no-cache --platform linux/amd64 -t rancher-go-test:latest -f validation/pipeline/Dockerfile.airgap-go-tests .'
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    property.useWithProperties([
                        'AWS_ACCESS_KEY_ID',
                        'AWS_SECRET_ACCESS_KEY',
                        'AWS_SSH_PEM_KEY',
                        'AWS_SSH_PEM_KEY_NAME',
                        'ADMIN_PASSWORD',
                        'QASE_AUTOMATION_TOKEN',
                        'APPCO_USERNAME',
                        'APPCO_ACCESS_TOKEN'
                    ]) {
                        def workspace = pwd()

                        // ── Write test config ─────────────────────────
                        if (!params.CONFIG?.trim()) {
                            error 'CONFIG parameter is empty — cannot run tests without a cattle-config'
                        }
                        writeFile file: 'validation/cattle-config.yaml', text: params.CONFIG.trim() + '\n'

                        // ── Build environment file for Docker ─────────
                        def envLines = []
                        envLines += "CATTLE_TEST_CONFIG=/workspace/validation/cattle-config.yaml"
                        envLines += "AWS_ACCESS_KEY_ID=${env.AWS_ACCESS_KEY_ID}"
                        envLines += "AWS_SECRET_ACCESS_KEY=${env.AWS_SECRET_ACCESS_KEY}"
                        envLines += "ADMIN_PASSWORD=${env.ADMIN_PASSWORD}"
                        if (env.APPCO_USERNAME) {
                            envLines += "APPCO_USERNAME=${env.APPCO_USERNAME}"
                        }
                        if (env.APPCO_ACCESS_TOKEN) {
                            envLines += "APPCO_ACCESS_TOKEN=${env.APPCO_ACCESS_TOKEN}"
                        }
                        if (env.QASE_AUTOMATION_TOKEN?.trim()) {
                            envLines += "QASE_AUTOMATION_TOKEN=${env.QASE_AUTOMATION_TOKEN}"
                        }
                        if (params.QASE_TEST_RUN_ID?.trim()) {
                            envLines += "QASE_TEST_RUN_ID=${params.QASE_TEST_RUN_ID}"
                        }
                        if (params.ENV_VARIABLE?.trim()) {
                            envLines += params.ENV_VARIABLE.trim()
                        }
                        def isPitJob = env.JOB_NAME.contains('go-pit')
                        if (isPitJob) {
                            envLines += "QASE_PROJECT_ID=RANCHERINT"
                            envLines += "TEST_RUN_NAME=${params.TAGS} Test Run"
                            envLines += "QASE_TEST_RUN_COMPLETE=true"
                        }
                        writeFile file: '.go_test_env', text: envLines.join('\n') + '\n'

                        // ── Start image capturer ──────────────────────
                        if (params.CAPTURE_IMAGES) {
                            catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                                sh 'mkdir -p ./validation/image-report'
                                sh """
                                    docker run -d --name imageCapturer \
                                        -v ${workspace}:/workspace \
                                        -v ${workspace}/validation/image-report:/app/image-report \
                                        -v ${workspace}/validation/cattle-config.yaml:/app/config.yaml \
                                        rancher-go-test:latest sh -c \
                                        'go build -o /app/capturer /workspace/scripts/capture_images/capture_images.go && \
                                        CATTLE_TEST_CONFIG=/app/config.yaml exec /app/capturer'
                                """
                                sh 'grep -qm 1 "Listening to events on cluster" <(docker logs -f imageCapturer)'
                            }
                        }

                        // ── Build gotestsum command ────────────────────
                        def goPackage = params.TEST_PACKAGE ?: './validation/...'
                        def testCmd = "gotestsum --format standard-verbose --packages=${goPackage} --junitfile /workspace/results.xml --jsonfile /workspace/results.json -- -tags=${params.TAGS}"

                        def testCase = params.GOTEST_TESTCASE?.trim()
                        if (testCase) {
                            testCmd += " ${testCase}"
                        }
                        testCmd += " -timeout=${params.TIMEOUT ?: '60m'} -v"

                        echo "Test command: ${testCmd}"

                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh """
                                docker run --rm --platform linux/amd64 \
                                    --env-file .go_test_env \
                                    -v ${workspace}:/workspace \
                                    -w /workspace \
                                    rancher-go-test:latest \
                                    sh -c 'set -e; set -o pipefail; ${testCmd} | tee /workspace/validation/go-test.log'
                            """
                        }

                        // ── Stop image capturer ───────────────────────
                        if (params.CAPTURE_IMAGES) {
                            catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                                sh 'docker stop imageCapturer'
                                echo readFile('./validation/image-report/image-report.txt')
                                sh 'docker rm imageCapturer'
                            }
                        }
                    }
                }
            }
        }

        stage('Report Results') {
            steps {
                script {
                    // JUnit results
                    junit allowEmptyResults: true, testResults: '**/results.xml'

                    // Archive test artifacts
                    archiveArtifacts allowEmptyArchive: true, artifacts: 'validation/go-test.log, results.xml, results.json, validation/image-report/**'

                    // Qase reporting
                    property.useWithProperties(['QASE_AUTOMATION_TOKEN']) {
                        if (env.QASE_AUTOMATION_TOKEN?.trim()) {
                            echo "Reporting results to Qase"

                            def workspace = pwd()
                            def reporterScript = params.QASE_REPORTER_SCRIPT ?: 'build_qase_reporter_v2.sh'
                            def imageReportMount = params.CAPTURE_IMAGES ? "-v ${workspace}/validation/image-report:/app/image-report" : ''
                            catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                                sh """
                                    docker run --rm --platform linux/amd64 \
                                        --env-file .go_test_env \
                                        -e BUILD_URL=${env.BUILD_URL} \
                                        -v ${workspace}:/home/runner/tests \
                                        ${imageReportMount} \
                                        -w /home/runner/tests \
                                        rancher-go-test:latest \
                                        sh -c '
                                            set -e
                                            validation/pipeline/scripts/${reporterScript}
                                            if [ -f /home/runner/tests/validation/reporter ]; then
                                                /home/runner/tests/validation/reporter
                                            else
                                                echo "Reporter binary not found — reporter script may have skipped build"
                                            fi
                                        '
                                """
                            }
                        } else {
                            echo 'Skipping Qase reporting: QASE_AUTOMATION_TOKEN not available'
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            sh 'docker rm -f imageCapturer || true'
            sh 'docker rmi -f rancher-go-test:latest || true'
            sh 'rm -f .go_test_env'
        }
    }
}
